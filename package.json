{
    "private": false,
    "name": "@actions-rs-plus/core",
    "version": "0.0.0",
    "author": "actions-rs-plus",
    "license": "MIT",
    "description": "Core functionality for the @actions-rs-plus repos",
    "type": "module",
    "main": "dist/core.js",
    "types": "dist/core.d.ts",
    "exports": {
        ".": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
    "engines": {
        "node": "24.18.0",
        "pnpm": "11.15.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/actions-rs-plus/core.git"
    },
    "bugs": {
        "url": "https://github.com/actions-rs-plus/core/issues"
    },
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "pnpm run lint --fix",
        "format": "prettier --write .",
        "clean": "rm -rf ./dist/* && rm tsconfig.tsbuildinfo && pnpm run build",
        "test": "vitest --coverage.enabled=true",
        "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
        "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
        "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
        "postversion": "cp package.json pnpm-lock.yaml ..",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "depcruise --config dependency-cruiser.config.mjs --validate -- "
        ],
        "*": [
            "eslint -- ",
            "prettier --ignore-unknown --"
        ]
    },
    "dependencies": {
        "@actions/cache": "^6.2.0",
        "@actions/core": "^3.0.1",
        "@actions/exec": "^3.0.0",
        "@actions/github": "^9.1.1",
        "@actions/http-client": "^4.0.1",
        "@actions/io": "^3.0.2",
        "@actions/tool-cache": "^4.0.0",
        "semver": "^7.8.5",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
        "@eslint/config-helpers": "0.6.0",
        "@eslint/core": "1.2.1",
        "@eslint/js": "10.0.1",
        "@microsoft/api-extractor": "7.58.11",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/eslint": "9.6.1",
        "@types/node": "24.13.3",
        "@types/semver": "7.7.1",
        "@typescript-eslint/parser": "8.64.0",
        "@vitest/coverage-v8": "4.1.10",
        "@vitest/ui": "4.1.10",
        "dependency-cruiser": "18.1.0",
        "eslint": "catalog:default",
        "eslint-config-love": "154.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-node": "0.4.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-n": "18.2.2",
        "eslint-plugin-perfectionist": "5.10.0",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-unicorn": "72.0.0",
        "husky": "9.1.7",
        "jiti": "2.7.0",
        "lint-staged": "17.1.0",
        "prettier": "3.9.5",
        "prettier-plugin-sh": "0.19.0",
        "prettier-plugin-toml": "2.0.6",
        "typescript": "6.0.3",
        "typescript-eslint": "8.64.0",
        "unplugin-dts": "1.0.3",
        "vite": "catalog:default",
        "vite-plugin-checker": "0.14.4",
        "vitest": "4.1.10"
    }
}
