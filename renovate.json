{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>kristof-mattei/renovate-config"],
    "forkProcessing": "enabled",
    "packageRules": [
        {
            "matchManagers": ["npm"],
            "matchDepTypes": ["dependencies"],
            "rangeStrategy": "update-lockfile"
        },
        {
            "matchPackageNames": ["tslib"],
            "rangeStrategy": "pin"
        }
    ]
}
